/* ============================== شبكة الخلفية المتحركة (Canvas) — التوقيع البصري ============================== */
(function networkBg(){
  const canvas = document.getElementById('networkCanvas');
  const ctx = canvas.getContext('2d');
  let W,H,nodes=[],pulses=[];
  const NODE_COUNT = 26;

  function resize(){
    const wrap = canvas.parentElement;
    W = canvas.width = wrap.clientWidth;
    H = canvas.height = wrap.clientHeight = 420;
    initNodes();
  }
  function initNodes(){
    nodes = Array.from({length:NODE_COUNT}, ()=>({
      x: Math.random()*W, y: Math.random()*H*0.9 + H*0.05,
      vx: (Math.random()-.5)*0.15, vy: (Math.random()-.5)*0.15,
      r: 1.6 + Math.random()*1.8
    }));
  }
  function maybeSpawnPulse(){
    if(Math.random() < 0.02 && nodes.length>1){
      const a = nodes[Math.floor(Math.random()*nodes.length)];
      const near = nodes.map(n=>({n, d:Math.hypot(n.x-a.x,n.y-a.y)})).sort((x,y)=>x.d-y.d).slice(1,4);
      const b = near[Math.floor(Math.random()*near.length)];
      if(b && b.d < 220){ pulses.push({a, b:b.n, t:0}); }
    }
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    nodes.forEach(n=>{
      n.x += n.vx; n.y += n.vy;
      if(n.x<0||n.x>W) n.vx*=-1;
      if(n.y<0||n.y>H) n.vy*=-1;
    });
    for(let i=0;i<nodes.length;i++){
      for(let j=i+1;j<nodes.length;j++){
        const d = Math.hypot(nodes[i].x-nodes[j].x, nodes[i].y-nodes[j].y);
        if(d < 165){
          ctx.strokeStyle = `rgba(139,160,190,${0.16*(1-d/165)})`;
          ctx.lineWidth = 1;
          ctx.beginPath(); ctx.moveTo(nodes[i].x,nodes[i].y); ctx.lineTo(nodes[j].x,nodes[j].y); ctx.stroke();
        }
      }
    }
    nodes.forEach(n=>{
      ctx.beginPath(); ctx.arc(n.x,n.y,n.r,0,Math.PI*2);
      ctx.fillStyle = 'rgba(200,210,230,0.55)'; ctx.fill();
    });
    maybeSpawnPulse();
    pulses = pulses.filter(p=>p.t<1);
    pulses.forEach(p=>{
      p.t += 0.012;
      const x = p.a.x + (p.b.x-p.a.x)*p.t;
      const y = p.a.y + (p.b.y-p.a.y)*p.t;
      const grad = ctx.createRadialGradient(x,y,0,x,y,7);
      grad.addColorStop(0, 'rgba(69,224,196,0.9)');
      grad.addColorStop(1, 'rgba(69,224,196,0)');
      ctx.fillStyle = grad;
      ctx.beginPath(); ctx.arc(x,y,7,0,Math.PI*2); ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize', resize);
  resize();
  if(!window.matchMedia('(prefers-reduced-motion: reduce)').matches){ draw(); }
  else { ctx.clearRect(0,0,W,H); }
})();

