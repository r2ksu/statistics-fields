    });
  }
  draw('all');
  document.getElementById('caseFilters').addEventListener('click', e=>{
    const btn = e.target.closest('.chip-filter');
    if(!btn) return;
    document.querySelectorAll('.chip-filter').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    draw(btn.dataset.sector);
  });
}

/* ============================== عارِض: أدوات التحليل (تفاعلي + Chart.js) ============================== */
let statsChart = null;
function renderTools(root){
  root.innerHTML = `
    <div class="glass-panel">
      <h3 style="font-size:15px;margin-bottom:16px">حاسبة الإحصاء الوصفي</h3>
      <div class="calc-grid">
        <div class="calc-field">
          <label>أدخل بياناتك (أرقام مفصولة بفواصل أو أسطر)</label>
          <textarea id="dataInput" placeholder="12, 15, 18, 9, 22, 14, 17">23, 45, 12, 67, 34, 29, 55, 41, 38, 19</textarea>
          <div style="margin-top:12px;display:flex;gap:10px">
            <button class="btn" id="calcBtn">${icon('cpu',15)} احسب وارسم</button>
            <button class="btn btn-ghost" id="randBtn">${icon('plus',15)} بيانات عشوائية</button>
          </div>
        </div>
        <div class="calc-field">
          <label>التوزيع التكراري</label>
          <div class="chart-wrap"><canvas id="statsCanvas"></canvas></div>
        </div>
      </div>
      <div class="result-strip" id="resultStrip"></div>
    </div>`;

  const cells = [
    {k:'n', l:'حجم العينة'}, {k:'mean', l:'المتوسط'}, {k:'std', l:'الانحراف المعياري'}, {k:'range', l:'المدى'}
  ];
  const strip = document.getElementById('resultStrip');
  strip.innerHTML = cells.map(c=>`<div class="result-cell"><b id="r_${c.k}">—</b><span>${c.l}</span></div>`).join('');

  function compute(){
    const raw = document.getElementById('dataInput').value;
    const nums = raw.split(/[,\u060C\n\s]+/).map(s=>parseFloat(s)).filter(v=>!isNaN(v));
    if(nums.length < 2){ return; }
    const n = nums.length;
    const mean = nums.reduce((a,b)=>a+b,0)/n;
    const variance = nums.reduce((a,b)=>a+Math.pow(b-mean,2),0)/(n-1);
    const std = Math.sqrt(variance);
    const range = Math.max(...nums) - Math.min(...nums);
    document.getElementById('r_n').textContent = n;
    document.getElementById('r_mean').textContent = mean.toFixed(2);
    document.getElementById('r_std').textContent = std.toFixed(2);
    document.getElementById('r_range').textContent = range.toFixed(2);

    const bins = 6;
    const min = Math.min(...nums), max = Math.max(...nums);
    const width = (max-min)/bins || 1;
    const counts = new Array(bins).fill(0);
    nums.forEach(v=>{ let idx = Math.floor((v-min)/width); if(idx>=bins) idx=bins-1; if(idx<0) idx=0; counts[idx]++; });
    const labels = counts.map((_,i)=> (min+i*width).toFixed(1));

    const ctx = document.getElementById('statsCanvas');
    if(statsChart) statsChart.destroy();
    statsChart = new Chart(ctx, {
      type:'bar',
      data:{ labels, datasets:[{ label:'التكرار', data: counts, backgroundColor:'rgba(69,224,196,0.55)', borderRadius:6, borderSkipped:false }]},
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{ display:false } },
        scales:{
          x:{ grid:{ color:'rgba(255,255,255,0.06)' }, ticks:{ color:'#8B93A7', font:{family:'IBM Plex Mono', size:10} } },
          y:{ grid:{ color:'rgba(255,255,255,0.06)' }, ticks:{ color:'#8B93A7', font:{family:'IBM Plex Mono', size:10} }, beginAtZero:true }
        }
      }
    });
  }

  document.getElementById('calcBtn').addEventListener('click', compute);
  document.getElementById('randBtn').addEventListener('click', ()=>{
    const arr = Array.from({length:14}, ()=> Math.round(10 + Math.random()*80));
    document.getElementById('dataInput').value = arr.join(', ');
    compute();
  });
  compute();
}

