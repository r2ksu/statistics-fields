<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Statistics &amp; Operations Research Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.4/chart.umd.min.js"></script>
<style>
/* ==========================================================================
   Statistics & Operations Research Hub
   بنية الملف: 1) متغيرات وأساسيات  2) تخطيط عام  3) مكوّنات  4) الصفحة الرئيسية
   5) قوالب الصفحات الداخلية  6) استجابة الجوال  7) حركات وانتقالات
   ========================================================================== */

:root{
  --bg: #090c12;
  --bg-alt: #0d121c;
  --glass: rgba(255,255,255,0.045);
  --glass-strong: rgba(255,255,255,0.075);
  --glass-border: rgba(255,255,255,0.09);
  --text: #eef1f7;
  --text-dim: #97a0b5;
  --text-faint: #5c6580;
  --accent: #45e0c4;      /* أخضر بياني - قياسات وتحليل */
  --accent-2: #8b7dfa;    /* بنفسجي - شبكات وأبحاث عمليات */
  --accent-3: #ffb454;    /* كهرماني - تنبيه وتمييز */
  --danger: #ff6b6b;
  --radius: 18px;
  --radius-sm: 12px;
  --shadow: 0 20px 60px rgba(0,0,0,0.45);
  --font-ar: 'IBM Plex Sans Arabic', 'Segoe UI', sans-serif;
  --font-mono: 'IBM Plex Mono', monospace;
  --ease: cubic-bezier(.22,.9,.32,1);
}

*{ margin:0; padding:0; box-sizing:border-box; }
html{ scroll-behavior:smooth; }
body{
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-ar);
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* خلفية أساسية: توهج خفيف + شبكة نقطية */
body::before{
  content:"";
  position: fixed; inset:0;
  background:
    radial-gradient(circle at 15% 8%, rgba(69,224,196,0.10), transparent 40%),
    radial-gradient(circle at 88% 18%, rgba(139,125,250,0.12), transparent 45%),
    radial-gradient(circle at 50% 100%, rgba(255,180,84,0.05), transparent 40%),
    var(--bg);
  z-index:-2;
}
body::after{
  content:"";
  position: fixed; inset:0;
  background-image: radial-gradient(rgba(255,255,255,0.045) 1px, transparent 1px);
  background-size: 26px 26px;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 40%, transparent 100%);
  z-index:-1;
  opacity:.5;
}

::selection{ background: var(--accent); color:#04120e; }
::-webkit-scrollbar{ width:10px; }
::-webkit-scrollbar-track{ background:transparent; }
::-webkit-scrollbar-thumb{ background: rgba(255,255,255,0.12); border-radius:10px; }
::-webkit-scrollbar-thumb:hover{ background: rgba(255,255,255,0.22); }

a{ color: inherit; text-decoration:none; }
button{ font-family: inherit; cursor:pointer; border:none; background:none; color:inherit; }
:focus-visible{ outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 6px; }

.mono{ font-family: var(--font-mono); direction: ltr; unicode-bidi: plaintext; }
.container{ max-width: 1180px; margin: 0 auto; padding: 0 24px; }

/* ============================== شريط علوي ============================== */
.topbar{
  position: sticky; top:0; z-index: 100;
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
  background: rgba(9,12,18,0.62);
  border-bottom: 1px solid var(--glass-border);
}
.topbar-inner{
  max-width:1180px; margin:0 auto; padding: 14px 24px;
  display:flex; align-items:center; justify-content:space-between; gap:18px;
}
.brand{ display:flex; align-items:center; gap:10px; cursor:pointer; }
.brand-mark{
  width:38px; height:38px; border-radius:11px; position:relative; flex-shrink:0;
  background: linear-gradient(155deg, var(--accent), var(--accent-2));
  display:flex; align-items:center; justify-content:center;
  box-shadow: 0 6px 20px rgba(69,224,196,0.25);
}
.brand-mark svg{ width:20px; height:20px; }
.brand-text{ display:flex; flex-direction:column; line-height:1.15; }
.brand-text b{ font-size:15px; font-weight:700; letter-spacing:.2px; }
.brand-text span{ font-size:11px; color:var(--text-faint); font-family:var(--font-mono); direction:ltr; }

.top-nav{ display:flex; align-items:center; gap:4px; }
.top-nav button{
  font-size: 13.5px; color: var(--text-dim); padding: 8px 12px; border-radius: 10px;
  transition: color .2s var(--ease), background .2s var(--ease);
  white-space:nowrap;
}
.top-nav button:hover{ color: var(--text); background: var(--glass); }
.top-nav button.active{ color: var(--bg); background: var(--accent); font-weight:600; }

.icon-btn{
  width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center;
  color: var(--text-dim); border:1px solid var(--glass-border); background: var(--glass);
  transition: .2s var(--ease);
}
.icon-btn:hover{ color: var(--text); border-color: rgba(255,255,255,0.2); }
.icon-btn svg{ width:17px; height:17px; }

/* ============================== هيرو + شبكة رسومية ============================== */
.hero{ position:relative; padding: 68px 24px 40px; overflow:hidden; }
.hero-canvas-wrap{
  position:absolute; inset:0; z-index:0;
  mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
}
#networkCanvas{ width:100%; height:100%; display:block; }
.hero-inner{ position:relative; z-index:1; max-width: 780px; margin: 0 auto; text-align:center; }
.eyebrow{
  display:inline-flex; align-items:center; gap:8px;
  font-family: var(--font-mono); font-size:12px; letter-spacing:.5px; color: var(--accent);
  background: rgba(69,224,196,0.08); border:1px solid rgba(69,224,196,0.25);
  padding:6px 14px; border-radius: 999px; margin-bottom:22px; direction:ltr;
}
.eyebrow span{ width:6px; height:6px; border-radius:50%; background:var(--accent); box-shadow:0 0 10px var(--accent); animation: pulse-dot 1.8s infinite; }
@keyframes pulse-dot{ 0%,100%{opacity:1} 50%{opacity:.3} }

.hero h1{
  font-size: clamp(30px, 5vw, 50px); font-weight:700; line-height:1.25; letter-spacing:-.5px;
  margin-bottom:16px;
}
.hero h1 em{
  font-style:normal;
  background: linear-gradient(90deg, var(--accent), var(--accent-2));
  -webkit-background-clip:text; background-clip:text; color:transparent;
}
.hero p.lead{ color: var(--text-dim); font-size:16px; line-height:1.9; max-width:600px; margin:0 auto 34px; }

.search-shell{ max-width: 560px; margin: 0 auto; position:relative; }
.search-box{
  display:flex; align-items:center; gap:10px;
  background: var(--glass); border:1px solid var(--glass-border);
  border-radius: 16px; padding: 14px 18px; backdrop-filter: blur(14px);
  transition: border-color .25s var(--ease), box-shadow .25s var(--ease);
}
.search-box:focus-within{ border-color: rgba(69,224,196,0.5); box-shadow: 0 0 0 4px rgba(69,224,196,0.08); }
.search-box svg{ width:18px; height:18px; color: var(--text-faint); flex-shrink:0; }
.search-box input{
  flex:1; background:transparent; border:none; color:var(--text); font-family:inherit; font-size:14.5px;
}
.search-box input::placeholder{ color: var(--text-faint); }
.search-kbd{
  font-family: var(--font-mono); font-size:11px; color:var(--text-faint);
  border:1px solid var(--glass-border); border-radius:6px; padding:2px 7px; direction:ltr;
}
.search-stats{ font-size:12px; color:var(--text-faint); margin-top:10px; font-family:var(--font-mono); direction:ltr; }

.hero-stats{
  display:flex; justify-content:center; gap: 38px; margin-top:44px; flex-wrap:wrap;
}
.hero-stat b{ font-family:var(--font-mono); font-size: 24px; font-weight:600; display:block;
  background: linear-gradient(90deg,var(--text), var(--text-dim)); -webkit-background-clip:text; background-clip:text; }
.hero-stat span{ font-size:12px; color:var(--text-faint); }

/* ============================== شبكة البطاقات ============================== */
.section-heading{ display:flex; align-items:baseline; justify-content:space-between; margin: 54px 0 20px; }
.section-heading h2{ font-size:19px; font-weight:600; }
.section-heading span{ font-size:12.5px; color:var(--text-faint); font-family:var(--font-mono); direction:ltr; }

.card-grid{
  display:grid; grid-template-columns: repeat(3, 1fr); gap:16px; padding-bottom:70px;
}
.hub-card{
  position:relative; border-radius: var(--radius);
  background: linear-gradient(160deg, var(--glass-strong), var(--glass));
  border:1px solid var(--glass-border);
  padding: 22px; text-align:right; overflow:hidden;
  transition: transform .35s var(--ease), border-color .35s var(--ease), box-shadow .35s var(--ease);
  min-height: 168px; display:flex; flex-direction:column; justify-content:space-between;
}
.hub-card::before{
  content:""; position:absolute; inset:0; opacity:0; transition: opacity .4s var(--ease);
  background: radial-gradient(240px circle at var(--mx,50%) var(--my,0%), rgba(69,224,196,0.14), transparent 60%);
}
.hub-card:hover::before{ opacity:1; }
.hub-card:hover{ transform: translateY(-4px); border-color: rgba(255,255,255,0.18); box-shadow: var(--shadow); }
.hub-card:active{ transform: translateY(-1px) scale(.995); }
.hub-card.hidden-card{ display:none; }

.hub-card-top{ display:flex; align-items:flex-start; justify-content:space-between; position:relative; z-index:1; }
.hub-icon{
  width:44px; height:44px; border-radius:13px; display:flex; align-items:center; justify-content:center;
  background: rgba(255,255,255,0.06); border:1px solid var(--glass-border);
}
.hub-icon svg{ width:21px; height:21px; }
.hub-arrow{ width:30px; height:30px; border-radius:9px; display:flex; align-items:center; justify-content:center;
  border:1px solid var(--glass-border); color:var(--text-faint); transition: .3s var(--ease); }
.hub-card:hover .hub-arrow{ background:var(--accent); color:#04120e; border-color:var(--accent); transform: rotate(-45deg); }
.hub-arrow svg{ width:14px; height:14px; }

.hub-card h3{ font-size:16.5px; font-weight:600; margin-top:18px; position:relative; z-index:1; }
.hub-card p{ font-size:12.8px; color:var(--text-dim); line-height:1.7; margin-top:6px; position:relative; z-index:1; }
.hub-tag{ font-family: var(--font-mono); font-size:10.5px; color:var(--text-faint); margin-top:14px; direction:ltr; position:relative; z-index:1; }

/* ============================== طبقات الصفحات الداخلية ============================== */
#homeView{ animation: viewIn .5s var(--ease); }
.page-view{ display:none; min-height: 70vh; padding: 26px 24px 90px; animation: viewIn .48s var(--ease); }
.page-view.active{ display:block; }
@keyframes viewIn{ from{ opacity:0; transform: translateY(14px);} to{ opacity:1; transform:translateY(0);} }
body.inner body::before{ }

.breadcrumb{
  display:flex; align-items:center; gap:8px; font-size:12.5px; color:var(--text-faint);
  max-width:1180px; margin:0 auto 22px; font-family:var(--font-mono); direction:ltr;
}
.breadcrumb button{ color:var(--text-dim); }
.breadcrumb button:hover{ color:var(--accent); }

.page-header{ max-width:1180px; margin:0 auto 34px; display:flex; align-items:center; gap:18px; }
.page-header .hub-icon{ width:56px; height:56px; border-radius:16px; }
.page-header .hub-icon svg{ width:26px; height:26px; }
.page-header h1{ font-size: clamp(22px,3vw,30px); font-weight:700; }
.page-header p{ color:var(--text-dim); font-size:13.5px; margin-top:4px; }

.page-body{ max-width:1180px; margin:0 auto; display:flex; flex-direction:column; gap:34px; }

/* بطاقة زجاجية عامة */
.glass-panel{
  background: linear-gradient(160deg, var(--glass-strong), var(--glass));
  border:1px solid var(--glass-border); border-radius: var(--radius); padding:24px;
}

/* شبكات محتوى متنوعة */
.grid-3{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
.grid-2{ display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
.grid-4{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }

/* مسارات مهنية */
.path-card{ padding:22px; border-radius:var(--radius-sm); }
.path-card .lvl{ display:flex; gap:6px; margin:10px 0 14px; }
.lvl i{ width:20px; height:5px; border-radius:3px; background: rgba(255,255,255,0.09); }
.lvl i.on{ background: linear-gradient(90deg,var(--accent),var(--accent-2)); }
.path-skills{ display:flex; flex-wrap:wrap; gap:6px; margin-top:12px; }
.chip{ font-size:11px; padding:4px 10px; border-radius:999px; background:rgba(255,255,255,0.06); border:1px solid var(--glass-border); color:var(--text-dim); }
.path-salary{ font-family:var(--font-mono); direction:ltr; text-align:left; margin-top:16px; font-size:13px; color:var(--accent); }

/* خارطة التعلم - جدول زمني */
.roadmap{ position:relative; padding-inline-start: 30px; }
.roadmap::before{ content:""; position:absolute; right:9px; top:6px; bottom:6px; width:2px;
  background: linear-gradient(var(--accent), var(--accent-2)); opacity:.35; }
.road-step{ position:relative; padding: 0 0 30px 0; padding-inline-end:30px; }
.road-step:last-child{ padding-bottom:0; }
.road-step::before{ content: attr(data-n); position:absolute; right:-30px; top:0; width:22px; height:22px; border-radius:50%;
  background: var(--bg-alt); border:2px solid var(--accent); display:flex; align-items:center; justify-content:center;
  font-family:var(--font-mono); font-size:10px; color:var(--accent); }
.road-step h4{ font-size:15px; margin-bottom:5px; }
.road-step p{ font-size:13px; color:var(--text-dim); line-height:1.8; }
.road-step .topics{ display:flex; flex-wrap:wrap; gap:6px; margin-top:9px; }

/* وظائف */
.job-row{ display:flex; align-items:flex-start; gap:16px; padding:16px; border-radius:var(--radius-sm); border:1px solid var(--glass-border); background:var(--glass); }
.job-logo{ width:44px; height:44px; border-radius:12px; background:rgba(255,255,255,0.07); display:flex; align-items:center; justify-content:center; font-weight:700; font-family:var(--font-mono); flex-shrink:0; }
.job-info{ flex:1; }
.job-info h4{ font-size:14.5px; }
.job-meta{ display:flex; gap:10px; margin-top:4px; font-size:11.5px; color:var(--text-faint); flex-wrap:wrap; }
.job-meta span{ display:flex; align-items:center; gap:4px; }
.job-role{ font-size:12.5px; color:var(--text-dim); line-height:1.75; margin-top:10px; max-width:640px; }
.job-badge{ font-size:11px; padding:5px 12px; border-radius:999px; border:1px solid rgba(69,224,196,0.3); color:var(--accent); background:rgba(69,224,196,0.07); white-space:nowrap; margin-top:2px; }

/* برامج/أدوات */
.tool-card{ padding:20px; border-radius:var(--radius-sm); text-align:center; }
.tool-card .tool-mark{ width:52px;height:52px;border-radius:14px;margin:0 auto 14px;display:flex;align-items:center;justify-content:center; font-family:var(--font-mono); font-weight:700; font-size:15px; }
.tool-card h4{ font-size:14px; margin-bottom:4px; }
.tool-card p{ font-size:11.5px; color:var(--text-faint); line-height:1.6; }

/* شهادات */
.cert-card{ padding:20px; border-radius:var(--radius-sm); display:flex; gap:14px; align-items:flex-start; }
.cert-card .hub-icon{ flex-shrink:0; }
.cert-card h4{ font-size:14.5px; margin-bottom:5px; }
.cert-card p{ font-size:12px; color:var(--text-dim); line-height:1.7; }
.cert-meta{ margin-top:8px; font-family:var(--font-mono); font-size:10.5px; color:var(--accent-3); direction:ltr; }

/* مشاريع */
.proj-card{ border-radius:var(--radius-sm); padding:20px; }
.proj-diff{ display:inline-block; font-size:10.5px; padding:3px 10px; border-radius:999px; margin-bottom:12px; font-family:var(--font-mono); }
.diff-1{ background:rgba(69,224,196,0.12); color:var(--accent); }
.diff-2{ background:rgba(255,180,84,0.12); color:var(--accent-3); }
.diff-3{ background:rgba(255,107,107,0.12); color:var(--danger); }
.proj-card h4{ font-size:15px; margin-bottom:8px; }
.proj-card p{ font-size:12.8px; color:var(--text-dim); line-height:1.75; }

/* دراسات حالة */
.chip-filter{ font-family:var(--font-mono); font-size:11.5px; border:1px solid var(--glass-border); color:var(--text-dim); transition:.2s var(--ease); }
.chip-filter:hover{ color:var(--text); border-color: rgba(255,255,255,0.25); }
.chip-filter.active{ background: var(--accent); color:#04120e; border-color:var(--accent); font-weight:600; }
.case-card{ padding:22px; border-radius:var(--radius-sm); }
.case-top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
.case-sector{ font-size:10.5px; padding:4px 11px; border-radius:999px; background:rgba(139,125,250,0.12); color:var(--accent-2); border:1px solid rgba(139,125,250,0.3); }
.case-org{ font-size:11.5px; color:var(--text-faint); direction:ltr; }
.case-card h4{ font-size:15.5px; margin-bottom:14px; }
.case-block{ margin-bottom:12px; }
.case-block b{ display:flex; align-items:center; gap:6px; font-size:11.5px; color:var(--accent-3); margin-bottom:4px; }
.case-block.result b{ color:var(--accent); }
.case-block p{ font-size:12.6px; color:var(--text-dim); line-height:1.75; }

/* أدوات التحليل التفاعلية */
.calc-grid{ display:grid; grid-template-columns: 1fr 1fr; gap:20px; }
.calc-field label{ font-size:12.5px; color:var(--text-dim); display:block; margin-bottom:8px; }
.calc-field textarea, .calc-field input{
  width:100%; background: rgba(255,255,255,0.04); border:1px solid var(--glass-border); border-radius:10px;
  padding:12px; color:var(--text); font-family:var(--font-mono); font-size:13px; direction:ltr; text-align:left;
}
.calc-field textarea{ resize:vertical; min-height:90px; }
.btn{
  display:inline-flex; align-items:center; gap:8px; background: linear-gradient(90deg,var(--accent),var(--accent-2));
  color:#04120e; font-weight:600; font-size:13.5px; padding:11px 20px; border-radius:11px; transition: transform .2s var(--ease), box-shadow .2s var(--ease);
}
.btn:hover{ transform: translateY(-2px); box-shadow: 0 10px 30px rgba(69,224,196,0.25); }
.btn-ghost{ background:var(--glass); color:var(--text); border:1px solid var(--glass-border); }
.result-strip{ display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-top:16px; }
.result-cell{ background:rgba(255,255,255,0.04); border:1px solid var(--glass-border); border-radius:10px; padding:12px; text-align:center; }
.result-cell b{ display:block; font-family:var(--font-mono); font-size:17px; color:var(--accent); }
.result-cell span{ font-size:10.5px; color:var(--text-faint); }
.chart-wrap{ position:relative; height:260px; margin-top:18px; }

/* أسئلة شائعة - أكورديون */
.faq-item{ border-radius:var(--radius-sm); border:1px solid var(--glass-border); background:var(--glass); overflow:hidden; }
.faq-q{ display:flex; align-items:center; justify-content:space-between; padding:17px 20px; font-size:14px; font-weight:500; }
.faq-q svg{ width:16px; height:16px; color:var(--text-faint); transition: transform .3s var(--ease); flex-shrink:0; }
.faq-item.open .faq-q svg{ transform: rotate(45deg); color:var(--accent); }
.faq-a{ max-height:0; overflow:hidden; transition: max-height .35s var(--ease); }
.faq-a-inner{ padding:0 20px 18px; font-size:13px; color:var(--text-dim); line-height:1.85; }
.faq-item.open .faq-a{ max-height:300px; }

/* قاموس المصطلحات */
.glossary-list{ display:flex; flex-direction:column; gap:2px; }
.term-row{ display:flex; gap:18px; padding:16px 4px; border-bottom:1px solid var(--glass-border); }
.term-row:last-child{ border-bottom:none; }
.term-en{ font-family:var(--font-mono); font-size:12.5px; color:var(--accent); min-width:170px; direction:ltr; text-align:left; flex-shrink:0; }
.term-ar{ flex:1; }
.term-ar b{ font-size:13.5px; display:block; margin-bottom:3px; }
.term-ar span{ font-size:12.5px; color:var(--text-dim); line-height:1.7; }
.az-jump{ display:flex; flex-wrap:wrap; gap:6px; margin-bottom:18px; }
.az-jump button{ font-family:var(--font-mono); font-size:11px; width:28px; height:28px; border-radius:8px; border:1px solid var(--glass-border); color:var(--text-faint); }
.az-jump button:hover{ color:var(--accent); border-color:var(--accent); }

/* مواد القسم */
.material-row{ display:flex; align-items:center; gap:14px; padding:15px; border-radius:var(--radius-sm); border:1px solid var(--glass-border); background:var(--glass); }
