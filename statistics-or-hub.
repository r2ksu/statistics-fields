const topNav = document.getElementById('topNav');
const cardGrid = document.getElementById('cardGrid');

SECTIONS.forEach(s=>{
  const b = document.createElement('button');
  b.textContent = s.title;
  b.onclick = ()=>Router.go(s.id);
  b.dataset.id = s.id;
  topNav.appendChild(b);

  const c = document.createElement('div');
  c.className = 'hub-card';
  c.dataset.kw = (s.title + ' ' + s.desc + ' ' + s.kw).toLowerCase();
  c.innerHTML = `
    <div>
      <div class="hub-card-top">
        <div class="hub-icon">${icon(s.icon,20)}</div>
        <div class="hub-arrow">${icon('arrow',13)}</div>
      </div>
      <h3>${s.title}</h3>
      <p>${s.desc}</p>
    </div>
    <div class="hub-tag">${s.tag}</div>`;
  c.addEventListener('mousemove', e=>{
    const r = c.getBoundingClientRect();
    c.style.setProperty('--mx', ((e.clientX-r.left)/r.width*100)+'%');
    c.style.setProperty('--my', ((e.clientY-r.top)/r.height*100)+'%');
  });
  c.addEventListener('click', ()=>Router.go(s.id));
  cardGrid.appendChild(c);
});

/* ============================== البحث ============================== */
const searchInput = document.getElementById('searchInput');
const searchStats = document.getElementById('searchStats');
searchInput.addEventListener('input', ()=>{
  const q = searchInput.value.trim().toLowerCase();
  let shown = 0;
  document.querySelectorAll('.hub-card').forEach((c,i)=>{
    const match = !q || c.dataset.kw.includes(q);
    c.classList.toggle('hidden-card', !match);
    if(match) shown++;
  });
  searchStats.textContent = q ? `${shown} / ${SECTIONS.length} RESULTS FOR "${q}"` : '';
});
document.addEventListener('keydown', e=>{
  if(e.key === '/' && document.activeElement !== searchInput){ e.preventDefault(); searchInput.focus(); }
});

/* ============================== الموجّه (Router) ============================== */
const pageContainer = document.getElementById('pageContainer');
const homeView = document.getElementById('homeView');

const RENDERERS = {
  careers: renderCareers, roadmap: renderRoadmap, programs: renderPrograms,
  certs: renderCerts, projects: renderProjects, cases: renderCases, tools: renderTools, faq: renderFaq,
  glossary: renderGlossary,
};

const Router = {
  go(id){
    if(!id || id==='home'){
      homeView.style.display = '';
      pageContainer.innerHTML = '';
      document.querySelectorAll('.top-nav button').forEach(b=>b.classList.remove('active'));
      window.scrollTo({top:0, behavior:'smooth'});
      history.replaceState(null,'','#home');
      return;
    }
    const section = SECTIONS.find(s=>s.id===id);
    if(!section) return;
    homeView.style.display = 'none';
    document.querySelectorAll('.top-nav button').forEach(b=>b.classList.toggle('active', b.dataset.id===id));

    pageContainer.innerHTML = `
      <div class="page-view active">
        <div class="breadcrumb">
          <button onclick="Router.go('home')">HOME</button> / <span>${id.toUpperCase()}</span>
        </div>
        <div class="page-header">
          <div class="hub-icon">${icon(section.icon,26)}</div>
          <div>
            <h1>${section.title}</h1>
            <p>${section.desc}</p>
          </div>
        </div>
        <div class="page-body" id="pageBody"></div>
      </div>`;
    RENDERERS[id] && RENDERERS[id](document.getElementById('pageBody'));
    window.scrollTo({top:0, behavior:'smooth'});
    history.replaceState(null,'','#'+id);
  }
};
window.Router = Router;

